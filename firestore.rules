/**
 * @file Firebase Security Rules for balanceUp handball club app
 * @updated 2026-02-28 - CRITICAL FIX: Team-Scoping Security
 *
 * SECURITY HARDENING:
 * - Team-scoped READ: Users can only see data from their own team(s)
 * - Team-scoped WRITE: Only team admins can modify their team's data
 * - Multi-tenancy isolation: Complete data separation between teams
 *
 * Core Philosophy:
 * - Team members can read their team's data
 * - Team admins can write their team's data
 * - No cross-team data access
 *
 * Data Structure:
 * - /clubs/{clubId}: Club profiles
 * - /teams/{teamId}: Team profiles (within clubs)
 * - /fines/{fineId}: Fines (MUST have teamId)
 * - /payments/{paymentId}: Payments (MUST have teamId)
 * - /users/{userId}: User profiles
 * - All collections REQUIRE teamId for multi-tenancy
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS (Must be defined FIRST!)
    // ============================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user is member of a specific team
    function isTeamMember(teamId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/teams/$(teamId)/teamMembers/$(request.auth.uid));
    }

    // Check if user is admin of a specific team
    function isTeamAdmin(teamId) {
      return isTeamMember(teamId) && 
             get(/databases/$(database)/documents/teams/$(teamId)/teamMembers/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // Check if user is member of a specific club
    function isClubMember(clubId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/clubs/$(clubId)/clubMembers/$(request.auth.uid));
    }

    // Check if user is admin of a specific club
    function isClubAdmin(clubId) {
      return isClubMember(clubId) && 
             get(/databases/$(database)/documents/clubs/$(clubId)/clubMembers/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // CRITICAL: Check if user has access to this teamId (in read operations)
    function canAccessTeam(teamId) {
      return isTeamMember(teamId);
    }

    // CRITICAL: Check if teamId in write operation matches user's team
    function isValidTeamId(teamId) {
      return isTeamMember(teamId);
    }

    // Legacy global admin check (deprecated, use team-scoped roles)
    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ============================================
    // CLUBS & TEAMS
    // ============================================
    
    match /clubs/{clubId} {
      // Any signed-in user can view clubs (for browsing/joining)
      allow get, list: if isSignedIn();
      
      // Any signed-in user can create a club (becomes owner)
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      
      // Only club admins can update their club
      allow update: if isClubAdmin(clubId);
      
      // Only club owner can delete
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      
      match /clubMembers/{memberUid} {
        // Club members can read member list
        allow read: if isClubMember(clubId);
        
        // Club admins can add/update/remove members
        // OR users can join themselves (self-registration)
        allow create: if isClubAdmin(clubId) || 
                        (request.auth.uid == memberUid && request.resource.data.role == 'member');
        
        allow update, delete: if isClubAdmin(clubId);
      }
    }

    match /teams/{teamId} {
      // Any signed-in user can view teams (for browsing/joining)
      allow get, list: if isSignedIn();
      
      // Create: Must be club member if team belongs to club
      allow create: if isSignedIn() && (
        !('clubId' in request.resource.data) || 
        isClubMember(request.resource.data.clubId)
      );
      
      // Update: Team admins OR club admins (if linked)
      allow update: if isTeamAdmin(teamId) || (
        'clubId' in resource.data && 
        isClubAdmin(resource.data.clubId)
      );
      
      // Delete: Team owner OR club owner
      allow delete: if isTeamAdmin(teamId);
      
      match /teamMembers/{memberUid} {
        // Team members can read member list
        allow read: if isTeamMember(teamId);
        
        // Team admins can manage members
        // OR users can join themselves
        // OR club admins can manage team members
        allow create: if isTeamAdmin(teamId) || 
                        (request.auth.uid == memberUid) ||
                        ('clubId' in get(/databases/$(database)/documents/teams/$(teamId)).data && 
                         isClubAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data.clubId));
        
        allow update, delete: if isTeamAdmin(teamId) || 
                                ('clubId' in get(/databases/$(database)/documents/teams/$(teamId)).data && 
                                 isClubAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data.clubId));
      }
    }

    match /teamInvites/{inviteCode} {
      // Anyone can read invites to join teams
      allow get, list: if isSignedIn();
      
      // Team admins can create invites
      allow create: if isSignedIn();
      
      // No updates/deletes (single-use invites)
      allow update, delete: if false;
    }

    // ============================================
    // USERS (Players)
    // ============================================

    match /users/{userId} {
      // Users can read their own profile
      // Team members can read other team members' profiles
      allow get: if isOwner(userId) || isAdmin();
      
      // List users: Only for team queries (frontend must filter by teamId)
      allow list: if isSignedIn();

      // Only owner or admin can create/update profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();

      // Only admin can delete players
      allow delete: if isAdmin();
    }

    // ============================================
    // FINES (Top-level collection) - TEAM-SCOPED
    // ============================================

    match /fines/{fineId} {
      // CRITICAL: Can only read fines from your team
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // CRITICAL: Can only create fines for your team (as admin)
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      // Can only update/delete fines from your team (as admin)
      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // PAYMENTS (Top-level collection) - TEAM-SCOPED
    // ============================================

    match /payments/{paymentId} {
      // CRITICAL: Can only read payments from your team
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Can only create payments for your team (as admin)
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      // Can only update/delete payments from your team (as admin)
      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // BEVERAGES (Catalog) - TEAM-SCOPED
    // ============================================

    match /beverages/{beverageId} {
      // Team members can read their team's beverage catalog
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can manage their catalog
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // BEVERAGE CONSUMPTIONS - TEAM-SCOPED
    // ============================================

    match /beverageConsumptions/{consumptionId} {
      // Team members can read consumption records
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can manage consumption records
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // DUES (Team fees, events, etc.) - TEAM-SCOPED
    // ============================================

    match /dues/{dueId} {
      // Team members can read dues
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can create/update/delete dues
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // DUE PAYMENTS - TEAM-SCOPED
    // ============================================

    match /duePayments/{paymentId} {
      // Team members can read due payments
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can manage due payments
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // TRANSACTIONS (History/Ledger) - TEAM-SCOPED
    // ============================================

    match /transactions/{transactionId} {
      // Team members can read transaction history
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can create transactions (immutable ledger)
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      // Updates/deletes are denied (immutable ledger)
      allow update, delete: if false;
    }

    // ============================================
    // PREDEFINED FINES (Templates) - TEAM-SCOPED
    // ============================================

    match /predefinedFines/{fineId} {
      // Team members can read fine templates
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          canAccessTeam(resource.data.teamId);

      // Team admins can manage templates
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      allow update, delete: if isSignedIn() && 
                               'teamId' in resource.data && 
                               isTeamAdmin(resource.data.teamId);
    }

    // ============================================
    // AUDIT LOGS - TEAM-SCOPED
    // ============================================

    match /auditLogs/{logId} {
      // Team admins can read their team's audit logs
      allow get, list: if isSignedIn() && 
                          'teamId' in resource.data && 
                          isTeamAdmin(resource.data.teamId);

      // Team admins can create audit logs (immutable)
      allow create: if isSignedIn() && 
                       'teamId' in request.resource.data && 
                       isTeamAdmin(request.resource.data.teamId);

      // No updates/deletes (immutable)
      allow update, delete: if false;
    }

    // ============================================
    // ADMINS (Legacy global admin - DEPRECATED)
    // ============================================
    match /admins/{uid} {
      // Only existing admins can read/write admin documents
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
      
      // NOTE: This collection is deprecated in favor of team-based roles
      // Use teams/{teamId}/teamMembers/{uid}.role instead
    }
  }
}
